    -- The Word Browser has its OWN sort: always raw suffix-match results, sorted
    -- by length shortest-first WITHIN each priority group. This is independent of
    -- sortMode and does NOT use the main window shuffle.
    local function SearchWords()
        for _, c in ipairs(WBList:GetChildren()) do
            if c:IsA("GuiObject") and c.Name ~= "UIListLayout" then c:Destroy() end
        end

        local eVal = WBEndBox.Text
        local lVal = tonumber(WBLengthBox.Text)
        if eVal == "Ends with..." then eVal = "" end
        eVal = eVal:lower():gsub("[%s%c]+", "")

        -- Push suffix filter into global config so main window respects it
        suffixMode = eVal
        Config.SuffixMode = eVal
        Config.SuffixModes = {}
        for part in eVal:gmatch("[^,]+") do
            local clean = part:gsub("[%s%c]+", "")
            if #clean > 0 then table.insert(Config.SuffixModes, clean) end
        end

        lengthMode = lVal or 0
        Config.LengthMode = lengthMode

        if UpdateList then UpdateList(lastDetected, lastRequiredLetter) end

        if eVal == "" and not lVal then return end

        -- Build suffix priority map for Word Browser results
        local suffixPriority = {}
        for idx, s in ipairs(Config.SuffixModes) do
            suffixPriority[s] = idx
        end

        local results = {}
        local limit = 200

        for _, w in ipairs(Words) do
            if not Blacklist[w] and not UsedWords[w] then
                local matchLen = (not lVal) or (#w == lVal)
                local matchEnd = false
                if eVal == "" then
                    matchEnd = true
                elseif #Config.SuffixModes > 1 then
                    for _, s in ipairs(Config.SuffixModes) do
                        if w:sub(-#s) == s then matchEnd = true break end
                    end
                else
                    matchEnd = (w:sub(-#eVal) == eVal)
                end

                if matchEnd and matchLen then
                    -- Compute priority for this word
                    local bestPriority = 999
                    for _, s in ipairs(Config.SuffixModes) do
                        if w:sub(-#s) == s then
                            local p = suffixPriority[s] or 999
                            if p < bestPriority then bestPriority = p end
                        end
                    end
                    table.insert(results, {word = w, priority = bestPriority})
                    if #results >= limit then break end
                end
            end
        end

        -- Word Browser always sorts: priority group first, then shortest within group
        table.sort(results, function(a, b)
            if a.priority ~= b.priority then return a.priority < b.priority end
            if #a.word ~= #b.word then return #a.word < #b.word end
            return a.word < b.word
        end)

        for i, entry in ipairs(results) do
            local w = entry.word
            local row = Instance.new("TextButton", WBList)
            row.Size = UDim2.new(1, -6, 0, 22)
            row.BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)
            row.Text = ""
            row.AutoButtonColor = false
            Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)
            row.MouseButton1Click:Connect(function()
                Tween(row, {BackgroundColor3 = THEME.Accent}, 0.2)
                task.delay(0.2, function()
                    Tween(row, {BackgroundColor3 = (i % 2 == 0) and Color3.fromRGB(25,25,30) or Color3.fromRGB(30,30,35)}, 0.2)
                end)
            end)
            local lbl = Instance.new("TextLabel", row)
            lbl.Text = w
            lbl.Font = Enum.Font.Gotham
            lbl.TextSize = 12
            lbl.TextColor3 = THEME.Text
            lbl.Size = UDim2.new(1, -10, 1, 0)
            lbl.Position = UDim2.new(0, 5, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        WBList.CanvasSize = UDim2.new(0,0,0, WBLayout.AbsoluteContentSize.Y)
        lastDetected = "---"
        forceUpdateList = true
    end

    WBSearchBtn.MouseButton1Click:Connect(SearchWords)
    WBEndBox.FocusLost:Connect(function(enter) if enter then SearchWords() end end)
    WBLengthBox.FocusLost:Connect(function(enter) if enter then SearchWords() end end)
    WordBrowserBtn.MouseButton1Click:Connect(function()
        WordBrowserFrame.Visible = not WordBrowserFrame.Visible
        WordBrowserFrame.Parent = nil
        WordBrowserFrame.Parent = ScreenGui
    end)
end

-- =============================================
-- CORE SORT LOGIC
-- =============================================

--[[
  ApplySort — called only on the MAIN WINDOW list.
  Word Browser has its own fixed sort (priority + shortest).

  suffixList: ordered list of suffix strings from Config.SuffixModes
  Each word gets a "priority group" = index of its best-matching suffix (1 = first/highest).
  Words with no suffix match get priority 999 (lowest).

  SHORTEST MODE:
    - Sort by priority group ASC
    - Within each priority group: sort by word length ASC, then alpha

  RANDOM MODE:
    - Sort by priority group ASC (groups stay in priority order)
    - Within each priority group: chunk into groups of 3 by length,
      shuffle each chunk of 3, then flatten.
      This means the first 3 of a priority group are length-shuffled,
      the next 3 are length-shuffled, etc.
      Result: roughly random but nearby lengths cluster together.
]]

local function HasMatchingSuffix(word, suffixGroups)
    -- Check if word matches ANY suffix in ANY tier
    if not suffixGroups or #suffixGroups == 0 then return false end
    
    for _, tierSuffixes in ipairs(suffixGroups) do
        for _, s in ipairs(tierSuffixes) do
            if #word >= #s and word:sub(-#s) == s then
                return true
            end
        end
    end
    return false
end

local function GetSuffixPriorityTier(word, suffixGroups)
    -- Returns tier index (1,2,3...) or 999 for no match
    if not suffixGroups or #suffixGroups == 0 then return 999 end
    
    for tierIdx, tierSuffixes in ipairs(suffixGroups) do
        for _, s in ipairs(tierSuffixes) do
            if #word >= #s and word:sub(-#s) == s then
                return tierIdx
            end
        end
    end
    return 999
end

local function ShuffleTable(t)
    for i = #t, 2, -1 do
        local j = math.random(i)
        t[i], t[j] = t[j], t[i]
    end
    return t
end

local function ApplySort(t, mode)
    -- Build suffix groups from Config.SuffixModes
    local suffixGroups = {}
    local allSuffixes = Config.SuffixModes or {}
    
    -- Group suffixes into tiers of 3
    for i = 1, #allSuffixes, 3 do
        local tier = {}
        for j = i, math.min(i + 2, #allSuffixes) do
            table.insert(tier, allSuffixes[j])
        end
        table.insert(suffixGroups, tier)
    end
    
    if mode == "Shortest" then
        -- SHORTEST MODE: Split into "has suffix" and "no suffix"
        local withSuffix = {}
        local withoutSuffix = {}
        
        for _, w in ipairs(t) do
            if HasMatchingSuffix(w, suffixGroups) then
                table.insert(withSuffix, w)
            else
                table.insert(withoutSuffix, w)
            end
        end
        
        -- Sort all suffix-matching words by length (shortest to longest)
        table.sort(withSuffix, function(a, b)
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        
        -- Sort non-matching words by length
        table.sort(withoutSuffix, function(a, b)
            if #a ~= #b then return #a < #b end
            return a < b
        end)
        
        -- Combine: all suffix words first (sorted by length), then non-suffix words
        local result = {}
        for _, w in ipairs(withSuffix) do table.insert(result, w) end
        for _, w in ipairs(withoutSuffix) do table.insert(result, w) end
        
        -- Write back into t
        for i = #t, 1, -1 do t[i] = nil end
        for i, w in ipairs(result) do t[i] = w end
        
    else
        -- RANDOM MODE: Preserve tiers, shuffle within each tier
        local groups = {}
        local priorityOrder = {}

        for _, w in ipairs(t) do
            local p = GetSuffixPriorityTier(w, suffixGroups)
            if not groups[p] then
                groups[p] = {}
                table.insert(priorityOrder, p)
            end
            table.insert(groups[p], w)
        end

        -- Remove duplicates and sort priority order
        local seen = {}
        local cleanOrder = {}
        for _, p in ipairs(priorityOrder) do
            if not seen[p] then
                seen[p] = true
                table.insert(cleanOrder, p)
            end
        end
        table.sort(cleanOrder)

        local result = {}
        
        for _, p in ipairs(cleanOrder) do
            local group = groups[p]
            ShuffleTable(group)
            for _, w in ipairs(group) do
                table.insert(result, w)
            end
        end

        -- Write back into t
        for i = #t, 1, -1 do t[i] = nil end
        for i, w in ipairs(result) do t[i] = w end
    end
end

-- =============================================
-- SEARCH HELPERS
-- =============================================

local function GetMatchLength(str, prefix)
    local len = 0
    local max = math.min(#str, #prefix)
    for i = 1, max do
        local pb = string.byte(prefix, i)
        if pb == 35 or pb == string.byte(str, i) then
            len = i
        else
            break
        end
    end
    return len
end

local function BinarySearchStart(list, prefix)
    local left = 1
    local right = #list
    local result = -1
    local pLen = #prefix
    while left <= right do
        local mid = math.floor((left + right) / 2)
        local word = list[mid]
        local sub = word:sub(1, pLen)
        if sub == prefix then
            result = mid
            right = mid - 1
        elseif sub < prefix then
            left = mid + 1
        else
            right = mid - 1
        end
    end
    return result
end

local function CheckSuffix(w)
    if suffixMode == "" then return true end
    local suffixList = Config.SuffixModes
    if suffixList and #suffixList > 1 then
        for _, s in ipairs(suffixList) do
            if #w >= #s and w:sub(-#s) == s then return true end
        end
        return false
    end
    return #w >= #suffixMode and w:sub(-#suffixMode) == suffixMode
end

-- =============================================
-- MAIN WINDOW UPDATE LIST
-- =============================================

local lastRequiredLetter = ""

UpdateList = function(detectedText, requiredLetter)
    local hash = (detectedText or "") .. "|" .. (requiredLetter or "") .. "|" .. (SearchBox.Text or "") .. "|" .. suffixMode .. "|" .. tostring(lengthMode)
    if hash == lastUpdateHash and not forceUpdateList then return end
    lastUpdateHash = hash

    local matches = {}
    local searchPrefix = detectedText
    local isBacktracked = false
    local manualSearch = false

    if SearchBox and SearchBox.Text ~= "" then
        searchPrefix = SearchBox.Text:lower():gsub("[%s%c]+", "")
        manualSearch = true
        if requiredLetter and searchPrefix:sub(1,1) ~= requiredLetter:sub(1,1):lower() then
            requiredLetter = nil
        end
    end

    if not manualSearch and requiredLetter and #requiredLetter > 0 then
        local reqLen = GetMatchLength(requiredLetter, searchPrefix)
        if reqLen == #searchPrefix and #requiredLetter > #searchPrefix then
            searchPrefix = requiredLetter
        end
    end

    local firstChar = searchPrefix:sub(1,1)
    if firstChar == "#" then firstChar = nil end
    if (not firstChar or firstChar == "") and requiredLetter then
        firstChar = requiredLetter:sub(1,1):lower()
    end

    local bucket
    if firstChar and firstChar ~= "" and Buckets then
        bucket = Buckets[firstChar] or {}
    else
        bucket = Words
    end

    local function CollectMatches(prefix, ignoreLengthFilter)
        local exacts = {}
        local partials = {}
        local maxPartialLen = 0
        local MAX_RESULTS = 100  -- Set your limit here
        
        local function checkWord(w)
            if Blacklist[w] or UsedWords[w] then return end
            
            if not CheckSuffix(w) then return end
            
            if not ignoreLengthFilter and lengthMode > 0 and #w ~= lengthMode then return end
            
            local mLen = GetMatchLength(w, prefix)
            if mLen == #prefix then
                table.insert(exacts, w)
                return true  -- Signal that we added a word
            elseif #exacts == 0 then
                if mLen > maxPartialLen then
                    maxPartialLen = mLen
                    partials = {w}
                    return true
                elseif mLen == maxPartialLen and mLen > 0 then
                    if #partials < 50 then 
                        table.insert(partials, w)
                        return true
                    end
                end
            end
            return false
        end
        
        local useBinary = not (prefix:find("#") or prefix:find("%*"))
        if useBinary and #prefix > 0 then
            local startIndex = BinarySearchStart(bucket, prefix)
            if startIndex ~= -1 then
                for i = startIndex, #bucket do
                    local w = bucket[i]
                    if w:sub(1, #prefix) ~= prefix then break end
                    local added = checkWord(w)
                    if added and #exacts >= MAX_RESULTS then break end  -- Stop at 100
                end
            end
        else
            for _, w in ipairs(bucket) do
                local added = checkWord(w)
                if added and #exacts >= MAX_RESULTS then break end  -- Stop at 100
            end
        end
        
        return exacts, partials, maxPartialLen
    end

    local exacts, partials, pLen = CollectMatches(searchPrefix, false)

    -- Fallback: ignore length filter if nothing found
    if #exacts == 0 and lengthMode > 0 then
        local fe, _, _ = CollectMatches(searchPrefix, true)
        if #fe > 0 then exacts = fe end
    end

    -- Pad list with shortest prefix matches if under 40 results and filters active
    if (suffixMode ~= "" or lengthMode > 0) and #exacts < 40 then
        local alreadyIn = {}
        for _, w in ipairs(exacts) do alreadyIn[w] = true end
        local padding = {}
        local startIndex = BinarySearchStart(bucket, searchPrefix)
        if startIndex ~= -1 then
            for i = startIndex, #bucket do
                local w = bucket[i]
                if w:sub(1, #searchPrefix) ~= searchPrefix then break end
                if not Blacklist[w] and not UsedWords[w] and not alreadyIn[w] then
                    table.insert(padding, w)
                end
            end
        end
        table.sort(padding, function(a, b) return #a < #b end)
        for _, w in ipairs(padding) do
            if #exacts >= 30 then break end
            table.insert(exacts, w)
        end
    end

    if #exacts > 0 then
        matches = exacts
        -- Trim to 100 if somehow more
        if #matches > 100 then
            local trimmed = {}
            for i = 1, 100 do
                table.insert(trimmed, matches[i])
            end
            matches = trimmed
        end
    elseif pLen > 0 then
        matches = partials
        searchPrefix = searchPrefix:sub(1, pLen)
        isBacktracked = true
    elseif requiredLetter and #requiredLetter > 0 then
        local reqChar = requiredLetter:sub(1,1):lower()
        if searchPrefix:sub(1,1):lower() ~= reqChar then
            local fallbackBucket = (Buckets and Buckets[reqChar]) or Words
            if fallbackBucket then
                for _, w in ipairs(fallbackBucket) do
                    if not Blacklist[w] and not UsedWords[w] then
                        local mLen = GetMatchLength(w, requiredLetter)
                        if mLen == #requiredLetter then
                            table.insert(matches, w)
                            if #matches >= 100 then break end  -- Stop at 100
                        end
                    end
                end
            end
            if #matches > 0 then
                searchPrefix = requiredLetter
                isBacktracked = true
            end
        end
    end

    if #matches > 0 then
        -- Separate suffix-matching words from padding
        local filtered = {}
        local padding = {}
        for _, w in ipairs(matches) do
            if CheckSuffix(w) and (lengthMode == 0 or #w == lengthMode) then
                table.insert(filtered, w)
            else
                table.insert(padding, w)
            end
        end

        -- Apply sort to each group independently — padding is always shortest
        ApplySort(filtered, sortMode)
        table.sort(padding, function(a, b)
            if #a ~= #b then return #a < #b end
            return a < b
        end)

        matches = {}
        for _, w in ipairs(filtered) do table.insert(matches, w) end
        for _, w in ipairs(padding) do table.insert(matches, w) end
    end

    local displayList = {}
    local maxDisplay = 15
    for i = 1, math.min(maxDisplay, #matches) do
        table.insert(displayList, matches[i])
    end

    if #matches > 0 and not isBacktracked then
        currentBestMatch = matches[1]
    else
        currentBestMatch = nil
    end

    if isBacktracked then
        local validPart = searchPrefix
        local invalidPart = (detectedText or ""):sub(#searchPrefix + 1)
        local accentRGB = ColorToRGB(THEME.Accent)
        StatusText.Text = "No match: <font color=\"rgb(" .. accentRGB .. ")\">" .. validPart .. "</font><font color=\"rgb(255,80,80)\">" .. invalidPart .. "</font>"
        StatusText.TextColor3 = THEME.SubText
    end

    for i = 1, math.max(#displayList, #ButtonCache) do
        local w = displayList[i]
        local btn = ButtonCache[i]

        if w then
            local lbl
            if not btn then
                btn = Instance.new("TextButton")
                btn.Size = UDim2.new(1, -6, 0, 30)
                btn.BackgroundColor3 = THEME.ItemBG
                btn.Text = ""
                btn.AutoButtonColor = false
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

                lbl = Instance.new("TextLabel", btn)
                lbl.Name = "Label"
                lbl.Size = UDim2.new(1, -20, 1, 0)
                lbl.Position = UDim2.new(0, 10, 0, 0)
                lbl.BackgroundTransparency = 1
                lbl.Font = Enum.Font.GothamMedium
                lbl.TextSize = 14
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.RichText = true

                btn.MouseEnter:Connect(function() Tween(btn, {BackgroundColor3 = Color3.fromRGB(45,45,55)}) end)
                btn.MouseLeave:Connect(function() Tween(btn, {BackgroundColor3 = THEME.ItemBG}) end)

                btn.MouseButton1Click:Connect(function()
                    local d = ButtonData[btn]
                    if d then
                        local l = btn:FindFirstChild("Label")
                        if l then l.TextColor3 = THEME.Success end
                        Tween(btn, {BackgroundColor3 = Color3.fromRGB(30,60,40)})
                        UsedWords[d.word] = tick()
                        forceUpdateList = true
                    end
                end)

                btn.Parent = ScrollList
                table.insert(ButtonCache, btn)
            else
                lbl = btn:FindFirstChild("Label")
                btn.Visible = true
                btn.Parent = ScrollList
                btn.BackgroundColor3 = THEME.ItemBG
                if lbl then lbl.TextColor3 = THEME.Text end
            end

            ButtonData[btn] = {word = w, detected = detectedText}

            local accentRGB = ColorToRGB(THEME.Accent)
            if i == 1 then accentRGB = "100,255,140"
            elseif i == 2 then accentRGB = "255,180,200"
            elseif i == 3 then accentRGB = "100,200,255"
            end

            local textRGB = ColorToRGB(THEME.Text)
            local displayText = ""
            if isBacktracked then
                local prefix = w:sub(1, #searchPrefix)
                local suffix = w:sub(#searchPrefix + 1)
                displayText = "<font color=\"rgb(" .. accentRGB .. ")\">" .. prefix .. "</font>"
                    .. "<font color=\"rgb(" .. textRGB .. ")\">" .. suffix .. "</font>"
            else
                local prefix = w:sub(1, #(detectedText or ""))
                local suffix = w:sub(#(detectedText or "") + 1)
                displayText = "<font color=\"rgb(" .. accentRGB .. ")\">" .. prefix .. "</font>"
                    .. "<font color=\"rgb(" .. textRGB .. ")\">" .. suffix .. "</font>"
            end

            if lbl then lbl.Text = displayText end
        else
            if btn then
                btn.Visible = false
                ButtonData[btn] = nil
            end
        end
    end

    ScrollList.CanvasSize = UDim2.new(0,0,0, UIListLayout.AbsoluteContentSize.Y)
end

